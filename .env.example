# ───────────────────────────────────────────────────────────────────────────
# Sendify — environment variables
# Copy this file to `.env` and fill in real values for local development.
# In production, set these as secrets in AWS Secrets Manager / Parameter Store.
# ───────────────────────────────────────────────────────────────────────────

# ── Core
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=run-`openssl rand -base64 32`-and-paste-here

# ── Database (Postgres)
# Local: identical DATABASE_URL + DIRECT_URL
# Production: DATABASE_URL = RDS Proxy pooler, DIRECT_URL = RDS instance (for migrations only)
DATABASE_URL=postgresql://sendify:sendify@localhost:5432/sendify?schema=public
DIRECT_URL=postgresql://sendify:sendify@localhost:5432/sendify?schema=public

# ── Redis (for BullMQ send queue)
REDIS_URL=redis://localhost:6379

# ── Amazon SES
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_CONFIGURATION_SET=sendify-default
SES_SNS_TOPIC_ARN=

# ── Amazon S3 (asset library)
S3_BUCKET=sendify-assets
S3_PUBLIC_BASE_URL=https://cdn.divain.space

# ── DeepL Pro
DEEPL_API_KEY=
DEEPL_API_HOST=api.deepl.com

# ── Google Gemini (Nano Banana / image generation)
GEMINI_API_KEY=

# ── Google Ads (Customer Match)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ── Shopify Plus (per-store credentials configured in DB; these are app-level)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://sendify.divain.space

# ── OpenAI (commercial-copy review pass)
OPENAI_API_KEY=

# ── Email (transactional from Sendify itself: approval notifications, etc.)
SENDIFY_FROM_EMAIL=divain@divainparfums.com

# ── Send throttling (matches your SES approved quota)
# Default 14/sec for new accounts. Bump to 200+ after AWS approves your sending limit increase.
SES_RATE_PER_SECOND=14

# ── Promotion webhook (HMAC-SHA256 signature shared with your upstream calendar)
PROMOTIONS_WEBHOOK_SECRET=run-`openssl rand -base64 32`-and-paste-here
